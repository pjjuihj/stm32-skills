{
  "name": "PWM 舵机键盘控制配置",
  "description": "PWM 舵机键盘控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["GPIO", "TIM3"],
  "pins": [
    {"pin": "PA0", "signal": "GPIO_Output", "label": "ROW_1"},
    {"pin": "PA1", "signal": "GPIO_Output", "label": "ROW_2"},
    {"pin": "PA2", "signal": "GPIO_Output", "label": "ROW_3"},
    {"pin": "PA3", "signal": "GPIO_Output", "label": "ROW_4"},
    {"pin": "PB0", "signal": "GPIO_Input", "label": "COL_1"},
    {"pin": "PB1", "signal": "GPIO_Input", "label": "COL_2"},
    {"pin": "PB2", "signal": "GPIO_Input", "label": "COL_3"},
    {"pin": "PB10", "signal": "GPIO_Input", "label": "COL_4"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "Keypad Control Servo",
    "keypad": "4x4 Matrix",
    "channels": 2,
    "features": ["Preset positions", "Step control"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
