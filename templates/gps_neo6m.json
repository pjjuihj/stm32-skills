{
  "name": "GPS NEO-6M 定位模块",
  "description": "NEO-6M GPS 定位模块串口通信",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "GPIO"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "GPS_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "GPS_RX"},
    {"pin": "PA8", "signal": "GPIO_Output", "label": "GPS_PWR"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 9600,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    }
  },
  "gps": {
    "constellations": ["GPS", "GLONASS", "Galileo"],
    "channels": 50,
    "sensitivity": "-162dBm",
    "update_rate": "1-10Hz",
    "accuracy": "2.5m CEP"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
