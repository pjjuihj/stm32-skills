{
  "name": "GSM SIM800 通信模块",
  "description": "SIM800 GSM/GPRS 通信模块",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "USART2", "GPIO"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "GSM_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "GSM_RX"},
    {"pin": "PA2", "signal": "USART2_TX", "mode": "Asynchronous", "label": "DEBUG_TX"},
    {"pin": "PA3", "signal": "USART2_RX", "mode": "Asynchronous", "label": "DEBUG_RX"},
    {"pin": "PB0", "signal": "GPIO_Output", "label": "GSM_PWR"},
    {"pin": "PB1", "signal": "GPIO_Output", "label": "GSM_RST"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 9600,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    },
    "USART2": {
      "BaudRate": 115200,
      "VirtualMode": "VM_ASYNC"
    }
  },
  "gsm": {
    "features": ["SMS", "Voice", "GPRS", "Bluetooth"],
    "bands": "850/900/1800/1900MHz",
    "gprs_class": "12",
    "sim_voltage": "3V/1.8V"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true},
    "USART2_IRQn": {"priority": 6, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
