{
  "name": "PWM 蜂鸣器配置",
  "description": "PWM 无源蜂鸣器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "BUZZER"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "500"
    }
  },
  "buzzer": {
    "type": "Passive",
    "frequency": "1-20kHz",
    "drive": "PWM",
    "sound": ["Beep", "Alarm", "Melody"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
