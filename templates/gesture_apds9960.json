{
  "name": "APDS9960 手势传感器配置",
  "description": "APDS9960 手势/颜色/接近传感器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA0", "signal": "GPIO_Input", "label": "APDS_INT"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "sensor": {
    "type": "APDS9960",
    "measurements": ["Gesture", "Proximity", "Ambient Light", "Color"],
    "gesture_distance": "10-20cm",
    "proximity_range": "0-255",
    "i2c_address": "0x39",
    "interface": "I2C + Interrupt"
  },
  "nvic": {
    "EXTI0_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
