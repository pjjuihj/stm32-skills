{
  "name": "土壤湿度传感器配置",
  "description": "电容式土壤湿度传感器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["ADC1"],
  "pins": [
    {"pin": "PA0", "signal": "ADC1_IN0", "mode": "ADC1_IN0", "label": "SOIL_MOISTURE"}
  ],
  "config": {
    "ADC1": {
      "Resolution": "ADC_RESOLUTION_12B",
      "ScanConvMode": "DISABLE",
      "ContinuousConvMode": "ENABLE",
      "ExternalTrigConv": "ADC_SOFTWARE_START",
      "DataAlign": "ADC_DATAALIGN_RIGHT"
    }
  },
  "sensor": {
    "type": "Capacitive Soil Moisture",
    "range": "0-100%",
    "voltage": "3.3V",
    "output": "Analog (0-3.3V)",
    "calibration": "required"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
