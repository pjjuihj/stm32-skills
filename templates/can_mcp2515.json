{
  "name": "MCP2515 CAN 总线配置",
  "description": "MCP2515 SPI CAN 总线控制器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["SPI1", "GPIO"],
  "pins": [
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA6", "signal": "SPI1_MISO", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"},
    {"pin": "PA4", "signal": "GPIO_Output", "label": "MCP_CS"},
    {"pin": "PA3", "signal": "GPIO_Output", "label": "MCP_RST"},
    {"pin": "PA2", "signal": "GPIO_Input", "label": "MCP_INT"}
  ],
  "config": {
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_2LINES",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE",
      "BaudRatePrescaler": "SPI_BAUDRATEPRESCALER_16"
    }
  },
  "can": {
    "type": "MCP2515",
    "baudrate": "125kbps / 250kbps / 500kbps / 1Mbps",
    "buffers": 2,
    "filters": 6,
    "masks": 2,
    "interface": "SPI"
  },
  "nvic": {
    "EXTI2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
