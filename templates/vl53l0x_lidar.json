{
  "name": "VL53L0X 激光测距配置",
  "description": "VL53L0X 激光测距传感器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA0", "signal": "GPIO_Input", "label": "VL53_INT"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "sensor": {
    "type": "VL53L0X",
    "range": "30-2000mm",
    "accuracy": "±3%",
    "resolution": "1mm",
    "measurement_time": "33ms",
    "i2c_address": "0x29",
    "interface": "I2C"
  },
  "nvic": {
    "EXTI0_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
