{
  "name": "TFT ILI9341 显示屏",
  "description": "ILI9341 2.4寸 TFT 彩色显示屏 SPI 通信",
  "mcu": "STM32F407VETx",
  "peripherals": ["SPI1", "GPIO"],
  "pins": [
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"},
    {"pin": "PA4", "signal": "GPIO_Output", "label": "TFT_CS"},
    {"pin": "PA3", "signal": "GPIO_Output", "label": "TFT_DC"},
    {"pin": "PA2", "signal": "GPIO_Output", "label": "TFT_RST"},
    {"pin": "PA1", "signal": "GPIO_Output", "label": "TFT_BL"}
  ],
  "config": {
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_1LINE",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE",
      "BaudRatePrescaler": "SPI_BAUDRATEPRESCALER_2"
    }
  },
  "display": {
    "resolution": "240x320",
    "color_depth": "16-bit (65K) / 18-bit (262K)",
    "interface": "SPI / Parallel",
    "controller": "ILI9341",
    "touch": "optional (XPT2046)"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
