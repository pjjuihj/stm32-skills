{
  "name": "串口示波器 + 信号发生器",
  "description": "ADC 采集 + DAC 输出 + 串口通信 + OLED 显示",
  "version": "1.0.0",
  "author": "STM32 Keil Workflow",
  "mcu": "STM32F407VETx",
  "package": "LQFP100",
  "clock": {
    "hse": 8,
    "sysclk": 168,
    "ahb": 168,
    "apb1": 42,
    "apb2": 84,
    "pll_m": 8,
    "pll_n": 336,
    "pll_p": 2
  },
  "peripherals": ["ADC1", "DAC", "USART2", "I2C1", "TIM5", "TIM9", "RCC", "SYS"],
  "pins": [
    {"pin": "PA6", "signal": "ADC1_IN6", "mode": "ADC1_IN6", "label": "SCOPE_IN", "description": "示波器 ADC 输入"},
    {"pin": "PA4", "signal": "DAC_OUT1", "mode": "DAC_OUT1", "label": "SIGGEN_OUT", "description": "信号发生器 DAC 输出"},
    {"pin": "PA2", "signal": "USART2_TX", "mode": "Asynchronous", "label": "UART_TX", "description": "串口发送"},
    {"pin": "PA3", "signal": "USART2_RX", "mode": "Asynchronous", "label": "UART_RX", "description": "串口接收"},
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C", "label": "OLED_SCL", "description": "OLED 时钟线"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C", "label": "OLED_SDA", "description": "OLED 数据线"},
    {"pin": "PA8", "signal": "GPIO_Output", "mode": "GPIO_Output", "label": "LED", "description": "状态指示灯"},
    {"pin": "PA13", "signal": "SYS_JTMS-SWDIO", "mode": "Serial_Wire", "label": "SWDIO", "description": "SWD 调试数据线"},
    {"pin": "PA14", "signal": "SYS_JTCK-SWCLK", "mode": "Serial_Wire", "label": "SWCLK", "description": "SWD 调试时钟线"}
  ],
  "config": {
    "ADC1": {
      "Resolution": "ADC_RESOLUTION_12B",
      "ScanConvMode": "DISABLE",
      "ContinuousConvMode": "DISABLE",
      "DiscontinuousConvMode": "DISABLE",
      "ExternalTrigConvEdge": "ADC_EXTERNALTRIGCONVEDGE_RISING",
      "ExternalTrigConv": "ADC_EXTERNALTRIGCONV_T9_TRGO",
      "DataAlign": "ADC_DATAALIGN_RIGHT",
      "NbrOfConversion": "1",
      "SamplingTime": "ADC_SAMPLETIME_84CYCLES"
    },
    "DAC": {
      "Trigger": "DAC_TRIGGER_T5_TRGO",
      "OutputBuffer": "DAC_OUTPUTBUFFER_ENABLE"
    },
    "USART2": {
      "BaudRate": 115200,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX",
      "OverSampling": "OVERSAMPLING_16"
    },
    "I2C1": {
      "ClockSpeed": 400000,
      "Mode": "I2C_MODE_I2C",
      "DutyCycle": "I2C_DUTYCYCLE_2",
      "OwnAddress1": 0,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT",
      "DualAddressMode": "I2C_DUALADDRESS_DISABLE",
      "GeneralCallMode": "I2C_GENERALCALL_DISABLE",
      "NoStretchMode": "I2C_NOSTRETCH_DISABLE"
    },
    "TIM5": {
      "Prescaler": 83,
      "Period": 1999,
      "CounterMode": "TIM_COUNTERMODE_UP",
      "ClockDivision": "TIM_CLOCKDIVISION_DIV1",
      "AutoReloadPreload": "TIM_AUTORELOAD_PRELOAD_ENABLE",
      "TriggerOutput": "TIM_TRGO_UPDATE"
    },
    "TIM9": {
      "Prescaler": 83,
      "Period": 999,
      "CounterMode": "TIM_COUNTERMODE_UP",
      "ClockDivision": "TIM_CLOCKDIVISION_DIV1",
      "AutoReloadPreload": "TIM_AUTORELOAD_PRELOAD_ENABLE",
      "TriggerOutput": "TIM_TRGO_UPDATE"
    }
  },
  "nvic": {
    "TIM5_IRQn": {"priority": 6, "subpriority": 0, "enabled": true},
    "TIM1_BRK_TIM9_IRQn": {"priority": 6, "subpriority": 0, "enabled": true},
    "USART2_IRQn": {"priority": 5, "subpriority": 0, "enabled": true},
    "I2C1_ER_IRQn": {"priority": 5, "subpriority": 0, "enabled": true},
    "I2C1_EV_IRQn": {"priority": 5, "subpriority": 0, "enabled": true}
  },
  "gpio": {
    "PA8": {
      "mode": "GPIO_MODE_OUTPUT_PP",
      "pull": "GPIO_NOPULL",
      "speed": "GPIO_SPEED_FREQ_LOW",
      "initial_state": "GPIO_PIN_RESET"
    }
  },
  "debug": {
    "interface": "SWD",
    "frequency": 4000,
    "reset_mode": "UNDER_RESET"
  },
  "build": {
    "toolchain": "MDK-ARM",
    "compiler": "ARMCC",
    "optimization": "-Og",
    "debug_info": true
  },
  "files": {
    "startup": "startup_stm32f407xx.s",
    "system": "system_stm32f4xx.c",
    "linker": "STM32F407VETx_FLASH.ld"
  }
}
