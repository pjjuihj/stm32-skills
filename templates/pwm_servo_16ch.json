{
  "name": "16 路舵机控制",
  "description": "PCA9685 16 路 PWM 舵机控制器",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "pca9685": {
    "address": "0x40-0x7F",
    "channels": 16,
    "resolution": "12-bit",
    "frequency": "24Hz-1526Hz",
    "interface": "I2C"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
