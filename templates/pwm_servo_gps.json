{
  "name": "PWM 舵机 GPS 控制配置",
  "description": "PWM 舵机 GPS 定位控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "USART2", "TIM3"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "GPS_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "GPS_RX"},
    {"pin": "PA2", "signal": "USART2_TX", "mode": "Asynchronous", "label": "SERVO_TX"},
    {"pin": "PA3", "signal": "USART2_RX", "mode": "Asynchronous", "label": "SERVO_RX"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 9600,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    },
    "USART2": {
      "BaudRate": 115200,
      "VirtualMode": "VM_ASYNC"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "GPS Servo Control",
    "gps": "NEO-6M/NEO-M8N",
    "channels": 2,
    "features": ["Auto-pointing", "Tracking"]
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true},
    "USART2_IRQn": {"priority": 6, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
