{
  "name": "SPI 配置模板",
  "description": "SPI 外设配置模板",
  "parameters": {
    "spi": {
      "type": "string",
      "default": "SPI1",
      "options": ["SPI1", "SPI2", "SPI3", "SPI4", "SPI5", "SPI6"],
      "description": "SPI 外设名称"
    },
    "mode": {
      "type": "string",
      "default": "Master",
      "options": ["Master", "Slave"],
      "description": "SPI 模式"
    },
    "direction": {
      "type": "string",
      "default": "FullDuplex",
      "options": ["FullDuplex", "HalfDuplex", "ReceiveOnly", "TransmitOnly"],
      "description": "SPI 方向"
    },
    "datasize": {
      "type": "integer",
      "default": 8,
      "options": [8, 16],
      "description": "数据大小"
    },
    "cpol": {
      "type": "string",
      "default": "Low",
      "options": ["Low", "High"],
      "description": "时钟极性"
    },
    "cpha": {
      "type": "string",
      "default": "Edge1",
      "options": ["Edge1", "Edge2"],
      "description": "时钟相位"
    },
    "prescaler": {
      "type": "integer",
      "default": 2,
      "options": [2, 4, 8, 16, 32, 64, 128, 256],
      "description": "预分频系数"
    }
  },
  "usage": "python cubemx_config.py --modify project.ioc --config-spi --spi SPI1 --spi-mode Master --spi-direction FullDuplex --spi-datasize 8"
}
