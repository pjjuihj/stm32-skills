{
  "name": "PWM 舵机速度控制配置",
  "description": "PWM 舵机速度控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3", "TIM2"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_PWM"},
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Encoder_Interface", "label": "SPEED_FB"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "1500"
    },
    "TIM2": {
      "EncoderMode": "TIM_ENCODERMODE_TI12",
      "Period": "65535"
    }
  },
  "servo": {
    "type": "Servo with Speed Control",
    "feedback": "Encoder",
    "speed_control": "PID",
    "speed_range": "0-1000 rpm"
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
