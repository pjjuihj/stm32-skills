{
  "name": "USB MSC 配置",
  "description": "USB 大容量存储设备配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USB_OTG_FS"],
  "pins": [
    {"pin": "PA11", "signal": "USB_OTG_FS_DM", "mode": "USB_OTG_FS"},
    {"pin": "PA12", "signal": "USB_OTG_FS_DP", "mode": "USB_OTG_FS"}
  ],
  "config": {
    "USB_OTG_FS": {
      "Mode": "DEVICE_VBUS",
      "Speed": "USB_OTG_FS_SPEED"
    }
  },
  "msc": {
    "type": "Mass Storage Class",
    "storage": ["Internal Flash", "SD Card", "SPI Flash"],
    "filesystem": "FAT12/FAT16/FAT32",
    "interface": "USB"
  },
  "nvic": {
    "OTG_FS_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
