{
  "name": "PWM 舵机矩阵控制配置",
  "description": "PWM 舵机矩阵控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1", "SPI1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    },
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_1LINE",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE"
    }
  },
  "servo": {
    "type": "Matrix Servo Control",
    "rows": 8,
    "columns": 8,
    "total_channels": 64,
    "controllers": ["PCA9685", "STP16CPC26"],
    "interface": "I2C + SPI"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
