{
  "name": "PWM 舵机电位器控制配置",
  "description": "PWM 舵机电位器控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["ADC1", "TIM3"],
  "pins": [
    {"pin": "PA0", "signal": "ADC1_IN0", "mode": "ADC1_IN0", "label": "POT_1"},
    {"pin": "PA1", "signal": "ADC1_IN1", "mode": "ADC1_IN1", "label": "POT_2"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "ADC1": {
      "Resolution": "ADC_RESOLUTION_12B",
      "ScanConvMode": "ENABLE",
      "ContinuousConvMode": "ENABLE",
      "NbrOfConversion": "2"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "Potentiometer Control Servo",
    "potentiometer": "10KΩ Linear",
    "channels": 2,
    "features": ["Direct mapping", "Smooth control"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
