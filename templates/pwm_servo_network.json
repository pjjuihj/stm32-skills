{
  "name": "PWM 舵机网络控制配置",
  "description": "PWM 舵机网络控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "USART2"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "SERVO_BUS_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "SERVO_BUS_RX"},
    {"pin": "PA2", "signal": "USART2_TX", "mode": "Asynchronous", "label": "DEBUG_TX"},
    {"pin": "PA3", "signal": "USART2_RX", "mode": "Asynchronous", "label": "DEBUG_RX"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 1000000,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    },
    "USART2": {
      "BaudRate": 115200,
      "VirtualMode": "VM_ASYNC"
    }
  },
  "servo": {
    "type": "Network Servo Control",
    "protocol": "Dynamixel / STS / SCS",
    "baudrate": "1Mbps",
    "max_servos": 254,
    "interface": "UART Half-Duplex"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true},
    "USART2_IRQn": {"priority": 6, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
