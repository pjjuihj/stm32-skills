{
  "name": "RTC 备份域配置",
  "description": "RTC 备份寄存器和电池备份配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["RTC", "PWR"],
  "pins": [
    {"pin": "PH0-OSC_IN", "signal": "RCC_OSC_IN", "mode": "LSE-External-Oscillator"},
    {"pin": "PH1-OSC_OUT", "signal": "RCC_OSC_OUT", "mode": "LSE-External-Oscillator"}
  ],
  "config": {
    "RTC": {
      "HourFormat": "RTC_HOURFORMAT_24",
      "AsynchPrediv": "127",
      "SynchPrediv": "255",
      "DateMode": "RTC_DATEMODE_DDMMYYYY"
    },
    "PWR": {
      "BackupRegulator": "ENABLE"
    }
  },
  "backup": {
    "registers": 20,
    "size": "4 bytes each",
    "total": "80 bytes",
    "battery": "VBAT pin",
    "retention": "years with battery"
  },
  "nvic": {
    "RTC_WKUP_IRQn": {"priority": 5, "enabled": true},
    "RTC_Alarm_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168,
    "lse": 32768
  }
}
