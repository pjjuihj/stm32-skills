{
  "name": "DMA SPI 配置",
  "description": "DMA 方式 SPI 通信",
  "mcu": "STM32F407VETx",
  "peripherals": ["SPI1", "DMA"],
  "pins": [
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA6", "signal": "SPI1_MISO", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"},
    {"pin": "PA4", "signal": "GPIO_Output", "label": "SPI_CS"}
  ],
  "config": {
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_2LINES",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE",
      "BaudRatePrescaler": "SPI_BAUDRATEPRESCALER_4"
    },
    "DMA2_Stream3": {
      "Channel": "DMA_CHANNEL_3",
      "Direction": "DMA_MEMORY_TO_PERIPH",
      "Mode": "DMA_NORMAL",
      "Priority": "DMA_PRIORITY_LOW"
    },
    "DMA2_Stream0": {
      "Channel": "DMA_CHANNEL_3",
      "Direction": "DMA_PERIPH_TO_MEMORY",
      "Mode": "DMA_NORMAL",
      "Priority": "DMA_PRIORITY_HIGH"
    }
  },
  "nvic": {
    "SPI1_IRQn": {"priority": 5, "enabled": true},
    "DMA2_Stream3_IRQn": {"priority": 6, "enabled": true},
    "DMA2_Stream0_IRQn": {"priority": 6, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
