{
  "name": "LoRa SX1278 无线通信",
  "description": "SX1278 LoRa 远距离无线通信模块",
  "mcu": "STM32F407VETx",
  "peripherals": ["SPI1", "GPIO"],
  "pins": [
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA6", "signal": "SPI1_MISO", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"},
    {"pin": "PA4", "signal": "GPIO_Output", "label": "LORA_CS"},
    {"pin": "PA3", "signal": "GPIO_Output", "label": "LORA_RST"},
    {"pin": "PA2", "signal": "GPIO_Input", "label": "LORA_DIO0"},
    {"pin": "PA1", "signal": "GPIO_Input", "label": "LORA_DIO1"}
  ],
  "config": {
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_2LINES",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE",
      "BaudRatePrescaler": "SPI_BAUDRATEPRESCALER_16"
    }
  },
  "lora": {
    "frequency": "433MHz/470MHz/868MHz/915MHz",
    "spreading_factor": "SF7-SF12",
    "bandwidth": "7.8kHz-500kHz",
    "coding_rate": "4/5-4/8",
    "max_power": "20dBm",
    "range": "5-15km"
  },
  "nvic": {
    "EXTI2_IRQn": {"priority": 5, "enabled": true},
    "EXTI1_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
