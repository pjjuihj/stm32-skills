{
  "name": "PWM 舵机称重控制配置",
  "description": "PWM 舵机称重传感器控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["GPIO", "TIM3"],
  "pins": [
    {"pin": "PA0", "signal": "GPIO_Output", "label": "HX711_SCK"},
    {"pin": "PA1", "signal": "GPIO_Input", "label": "HX711_DOUT"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "Weight Control Servo",
    "weight_sensor": "HX711",
    "channels": 2,
    "features": ["Weight-based control", "Auto-sorting"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
