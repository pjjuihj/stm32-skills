{
  "name": "旋转编码器配置",
  "description": "旋转编码器接口配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM2", "GPIO"],
  "pins": [
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Encoder_Interface", "label": "ENC_A"},
    {"pin": "PA1", "signal": "TIM2_CH2", "mode": "Encoder_Interface", "label": "ENC_B"},
    {"pin": "PB0", "signal": "GPIO_Input", "label": "ENC_BTN"}
  ],
  "config": {
    "TIM2": {
      "EncoderMode": "TIM_ENCODERMODE_TI12",
      "Period": "65535",
      "IC1Polarity": "TIM_ICPOLARITY_RISING",
      "IC2Polarity": "TIM_ICPOLARITY_RISING"
    }
  },
  "encoder": {
    "type": "Incremental",
    "ppr": "100-600",
    "quadrature": "4x",
    "button": "optional",
    "debounce": "required"
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
