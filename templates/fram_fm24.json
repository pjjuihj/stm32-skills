{
  "name": "FRAM FM24 配置",
  "description": "FM24 系列 I2C FRAM 配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "fram": {
    "type": "FM24CL04 / FM24CL16 / FM24CL64",
    "capacity": "512B - 64KB",
    "write_cycles": "10^14",
    "write_time": "instant",
    "data_retention": "10 years at 85°C",
    "i2c_address": "0x50",
    "interface": "I2C"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
