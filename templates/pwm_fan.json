{
  "name": "PWM 风扇控制配置",
  "description": "PWM 风扇转速控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3", "TIM2"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "FAN_PWM"},
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Input_Capture", "label": "FAN_TACH"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "500"
    },
    "TIM2": {
      "Prescaler": "84-1",
      "Period": "65535",
      "IC1Polarity": "TIM_ICPOLARITY_RISING"
    }
  },
  "fan": {
    "type": "4-wire PWM Fan",
    "pwm_frequency": "25kHz",
    "speed_range": "0-100%",
    "tachometer": "2 pulses per revolution"
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
