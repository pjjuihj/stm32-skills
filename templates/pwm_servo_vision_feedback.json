{
  "name": "PWM 舵机视觉反馈控制配置",
  "description": "PWM 舵机摄像头视觉反馈控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["DCMI", "I2C1", "TIM3"],
  "pins": [
    {"pin": "PA4", "signal": "DCMI_HSYNC", "mode": "DCMI"},
    {"pin": "PB7", "signal": "DCMI_VSYNC", "mode": "DCMI"},
    {"pin": "PA6", "signal": "DCMI_D0", "mode": "DCMI"},
    {"pin": "PA7", "signal": "DCMI_D1", "mode": "DCMI"},
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PB0", "signal": "TIM3_CH3", "mode": "PWM Generation3 CH3", "label": "SERVO_PAN"},
    {"pin": "PB1", "signal": "TIM3_CH4", "mode": "PWM Generation4 CH4", "label": "SERVO_TILT"}
  ],
  "config": {
    "DCMI": {
      "CaptureRate": "DCMI_CR_ALL_FRAME",
      "SynchroMode": "DCMI_SYNCHRO_HARDWARE"
    },
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation3 CH3": "TIM_CHANNEL_3",
      "Channel-PWM Generation4 CH4": "TIM_CHANNEL_4",
      "Pulse-PWM Generation3 CH3": "1500",
      "Pulse-PWM Generation4 CH4": "1500"
    }
  },
  "servo": {
    "type": "Vision Feedback Servo",
    "camera": "OV7670/OV2640",
    "channels": 2,
    "control": "Visual Servoing",
    "features": ["Object tracking", "Face tracking", "Color tracking"]
  },
  "nvic": {
    "DCMI_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
