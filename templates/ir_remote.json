{
  "name": "红外遥控配置",
  "description": "红外接收和发射",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM2", "TIM3", "GPIO"],
  "pins": [
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Input_Capture", "label": "IR_RX"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "IR_TX"}
  ],
  "config": {
    "TIM2": {
      "Prescaler": "84-1",
      "Period": "65535",
      "IC1Polarity": "TIM_ICPOLARITY_BOTHEDGE"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "500"
    }
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
