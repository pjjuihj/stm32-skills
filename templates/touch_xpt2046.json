{
  "name": "触摸屏 XPT2046",
  "description": "XPT2046 电阻式触摸屏控制器",
  "mcu": "STM32F407VETx",
  "peripherals": ["SPI1", "GPIO"],
  "pins": [
    {"pin": "PA5", "signal": "SPI1_SCK", "mode": "Full_Duplex_Master"},
    {"pin": "PA6", "signal": "SPI1_MISO", "mode": "Full_Duplex_Master"},
    {"pin": "PA7", "signal": "SPI1_MOSI", "mode": "Full_Duplex_Master"},
    {"pin": "PA4", "signal": "GPIO_Output", "label": "TOUCH_CS"},
    {"pin": "PA3", "signal": "GPIO_Input", "label": "TOUCH_IRQ"}
  ],
  "config": {
    "SPI1": {
      "Mode": "SPI_MODE_MASTER",
      "Direction": "SPI_DIRECTION_2LINES",
      "DataSize": "SPI_DATASIZE_8BIT",
      "CLKPolarity": "SPI_POLARITY_LOW",
      "CLKPhase": "SPI_PHASE_1EDGE",
      "BaudRatePrescaler": "SPI_BAUDRATEPRESCALER_16"
    }
  },
  "touch": {
    "type": "Resistive",
    "controller": "XPT2046",
    "resolution": "12-bit",
    "interface": "SPI",
    "calibration": "required"
  },
  "nvic": {
    "EXTI3_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
