{
  "name": "PWM 舵机 RS485 控制配置",
  "description": "PWM 舵机 RS485 总线控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "TIM3", "GPIO"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "RS485_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "RS485_RX"},
    {"pin": "PB0", "signal": "GPIO_Output", "label": "RS485_DE"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"},
    {"pin": "PB1", "signal": "TIM3_CH3", "mode": "PWM Generation3 CH3", "label": "SERVO_3"},
    {"pin": "PB2", "signal": "TIM3_CH4", "mode": "PWM Generation4 CH4", "label": "SERVO_4"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 115200,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Channel-PWM Generation3 CH3": "TIM_CHANNEL_3",
      "Channel-PWM Generation4 CH4": "TIM_CHANNEL_4",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500",
      "Pulse-PWM Generation3 CH3": "1500",
      "Pulse-PWM Generation4 CH4": "1500"
    }
  },
  "servo": {
    "type": "RS485 Servo Control",
    "rs485_baudrate": "115200",
    "channels": 4,
    "protocol": "Modbus RTU / custom"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
