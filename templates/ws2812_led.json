{
  "name": "WS2812 RGB LED 灯带",
  "description": "WS2812 可编程 RGB LED 灯带控制",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3", "DMA"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "WS2812_DATA"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "0",
      "Period": "105-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "0"
    },
    "DMA1_Stream4": {
      "Channel": "DMA_CHANNEL_5",
      "Direction": "DMA_MEMORY_TO_PERIPH",
      "Mode": "DMA_NORMAL",
      "Priority": "DMA_PRIORITY_HIGH"
    }
  },
  "led": {
    "type": "WS2812B",
    "color_depth": "24-bit (RGB)",
    "protocol": "One-wire",
    "timing": {"T0H": "400ns", "T0L": "850ns", "T1H": "800ns", "T1L": "450ns"},
    "max_leds": 1000,
    "refresh_rate": "30-60Hz"
  },
  "nvic": {
    "DMA1_Stream4_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
