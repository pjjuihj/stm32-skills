{
  "name": "PWM 电机调速配置",
  "description": "PWM 电机转速控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3", "TIM2", "GPIO"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "MOTOR_PWM"},
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Encoder_Interface", "label": "MOTOR_ENC_A"},
    {"pin": "PA1", "signal": "TIM2_CH2", "mode": "Encoder_Interface", "label": "MOTOR_ENC_B"},
    {"pin": "PB0", "signal": "GPIO_Output", "label": "MOTOR_DIR"},
    {"pin": "PB1", "signal": "GPIO_Output", "label": "MOTOR_EN"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "0"
    },
    "TIM2": {
      "EncoderMode": "TIM_ENCODERMODE_TI12",
      "Period": "65535"
    }
  },
  "motor": {
    "type": "DC Motor with Encoder",
    "pwm_frequency": "1kHz",
    "speed_control": "PID",
    "encoder_ppr": "100-1000"
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
