{
  "name": "PWM 舵机姿态反馈控制配置",
  "description": "PWM 舵机 IMU 姿态反馈控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1", "TIM3"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_PITCH"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_ROLL"},
    {"pin": "PB0", "signal": "TIM3_CH3", "mode": "PWM Generation3 CH3", "label": "SERVO_YAW"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Channel-PWM Generation3 CH3": "TIM_CHANNEL_3",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500",
      "Pulse-PWM Generation3 CH3": "1500"
    }
  },
  "servo": {
    "type": "Orientation Feedback Servo",
    "imu": "MPU6050/MPU9250/BMI160",
    "channels": 3,
    "control": "Attitude Control",
    "features": ["Stabilization", "Auto-level", "Gimbal control"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
