{
  "name": "PWM 舵机激光雷达控制配置",
  "description": "PWM 舵机激光雷达控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1", "TIM3"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA0", "signal": "GPIO_Input", "label": "LIDAR_INT"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_PAN"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_TILT"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "LiDAR Control Servo",
    "lidar": "VL53L0X/LIDAR-Lite",
    "channels": 2,
    "features": ["3D scanning", "Mapping"]
  },
  "nvic": {
    "EXTI0_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
