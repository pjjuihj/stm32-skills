{
  "name": "红外 NEC 协议配置",
  "description": "红外 NEC 协议发射接收配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM2", "TIM3", "GPIO"],
  "pins": [
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Input_Capture", "label": "IR_RX"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "IR_TX"}
  ],
  "config": {
    "TIM2": {
      "Prescaler": "84-1",
      "Period": "65535",
      "IC1Polarity": "TIM_ICPOLARITY_BOTHEDGE"
    },
    "TIM3": {
      "Prescaler": "22-1",
      "Period": "100-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "50"
    }
  },
  "ir": {
    "protocol": "NEC",
    "carrier_frequency": "38kHz",
    "data_bits": 32,
    "address_bits": 16,
    "command_bits": 16,
    "range": "5-10m"
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
