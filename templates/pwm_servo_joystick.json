{
  "name": "PWM 舵机摇杆控制配置",
  "description": "PWM 舵机摇杆控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["ADC1", "TIM3", "GPIO"],
  "pins": [
    {"pin": "PA0", "signal": "ADC1_IN0", "mode": "ADC1_IN0", "label": "JOY_X"},
    {"pin": "PA1", "signal": "ADC1_IN1", "mode": "ADC1_IN1", "label": "JOY_Y"},
    {"pin": "PB0", "signal": "GPIO_Input", "label": "JOY_BTN"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_X"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_Y"}
  ],
  "config": {
    "ADC1": {
      "Resolution": "ADC_RESOLUTION_12B",
      "ScanConvMode": "ENABLE",
      "ContinuousConvMode": "ENABLE",
      "NbrOfConversion": "2"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "Joystick Control Servo",
    "joystick": "Analog 2-axis",
    "channels": 2,
    "features": ["Proportional control", "Deadzone"]
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
