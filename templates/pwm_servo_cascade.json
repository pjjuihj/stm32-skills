{
  "name": "PWM 舵机级联控制配置",
  "description": "PWM 舵机级联控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["I2C1"],
  "pins": [
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"}
  ],
  "config": {
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "servo": {
    "type": "Cascaded Servo Control",
    "controller": "PCA9685",
    "channels_per_board": 16,
    "cascade_boards": 4,
    "total_channels": 64,
    "interface": "I2C"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
