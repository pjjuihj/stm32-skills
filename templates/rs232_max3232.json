{
  "name": "RS232 MAX3232 配置",
  "description": "RS232 MAX3232 电平转换配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 115200,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    }
  },
  "rs232": {
    "type": "MAX3232",
    "voltage": "3.3V",
    "baudrate": "up to 1Mbps",
    "channels": 2,
    "interface": "UART"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
