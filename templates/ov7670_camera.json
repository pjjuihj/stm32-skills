{
  "name": "OV7670 摄像头配置",
  "description": "OV7670 摄像头模块配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["DCMI", "I2C1", "GPIO"],
  "pins": [
    {"pin": "PA4", "signal": "DCMI_HSYNC", "mode": "DCMI"},
    {"pin": "PB7", "signal": "DCMI_VSYNC", "mode": "DCMI"},
    {"pin": "PA6", "signal": "DCMI_D0", "mode": "DCMI"},
    {"pin": "PA7", "signal": "DCMI_D1", "mode": "DCMI"},
    {"pin": "PB0", "signal": "DCMI_D2", "mode": "DCMI"},
    {"pin": "PB1", "signal": "DCMI_D3", "mode": "DCMI"},
    {"pin": "PB6", "signal": "I2C1_SCL", "mode": "I2C"},
    {"pin": "PB7", "signal": "I2C1_SDA", "mode": "I2C"},
    {"pin": "PA1", "signal": "GPIO_Output", "label": "CAM_RST"},
    {"pin": "PA2", "signal": "GPIO_Output", "label": "CAM_PWDN"}
  ],
  "config": {
    "DCMI": {
      "CaptureRate": "DCMI_CR_ALL_FRAME",
      "SynchroMode": "DCMI_SYNCHRO_HARDWARE",
      "PCKPolarity": "DCMI_PCKPOLARITY_RISING",
      "VSPolarity": "DCMI_VSPOLARITY_HIGH",
      "HSPolarity": "DCMI_HSPOLARITY_HIGH"
    },
    "I2C1": {
      "Speed": 400000,
      "AddressingMode": "I2C_ADDRESSINGMODE_7BIT"
    }
  },
  "camera": {
    "sensor": "OV7670",
    "resolution": "640x480 (VGA)",
    "format": "RGB565 / YUV422 / GRAY",
    "interface": "DCMI + I2C (SCCB)",
    "frame_rate": "30fps @ VGA"
  },
  "nvic": {
    "DCMI_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
