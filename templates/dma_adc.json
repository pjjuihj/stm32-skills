{
  "name": "DMA ADC 配置",
  "description": "DMA 方式 ADC 多通道采集",
  "mcu": "STM32F407VETx",
  "peripherals": ["ADC1", "DMA", "TIM2"],
  "pins": [
    {"pin": "PA0", "signal": "ADC1_IN0", "mode": "ADC1_IN0", "label": "CH0"},
    {"pin": "PA1", "signal": "ADC1_IN1", "mode": "ADC1_IN1", "label": "CH1"},
    {"pin": "PA2", "signal": "ADC1_IN2", "mode": "ADC1_IN2", "label": "CH2"},
    {"pin": "PA3", "signal": "ADC1_IN3", "mode": "ADC1_IN3", "label": "CH3"}
  ],
  "config": {
    "ADC1": {
      "ScanConvMode": "ENABLE",
      "ContinuousConvMode": "DISABLE",
      "ExternalTrigConv": "ADC_EXTERNALTRIGCONV_T2_TRGO",
      "DataAlign": "ADC_DATAALIGN_RIGHT",
      "NbrOfConversion": "4",
      "DMAContinuousRequests": "ENABLE"
    },
    "DMA2_Stream0": {
      "Channel": "DMA_CHANNEL_0",
      "Direction": "DMA_PERIPH_TO_MEMORY",
      "Mode": "DMA_CIRCULAR",
      "Priority": "DMA_PRIORITY_HIGH"
    },
    "TIM2": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "TriggerOutput": "TIM_TRGO_UPDATE"
    }
  },
  "nvic": {
    "DMA2_Stream0_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
