{
  "name": "PWM 舵机编码器控制配置",
  "description": "PWM 舵机编码器控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM2", "TIM3"],
  "pins": [
    {"pin": "PA0", "signal": "TIM2_CH1_ETR", "mode": "Encoder_Interface", "label": "ENC_A"},
    {"pin": "PA1", "signal": "TIM2_CH2", "mode": "Encoder_Interface", "label": "ENC_B"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "TIM2": {
      "EncoderMode": "TIM_ENCODERMODE_TI12",
      "Period": "65535"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "Encoder Control Servo",
    "encoder": "Rotary Encoder",
    "channels": 2,
    "features": ["Position feedback", "Speed control"]
  },
  "nvic": {
    "TIM2_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
