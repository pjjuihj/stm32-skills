{
  "name": "气体传感器配置",
  "description": "MQ-2/MQ-135 气体传感器配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["ADC1"],
  "pins": [
    {"pin": "PA0", "signal": "ADC1_IN0", "mode": "ADC1_IN0", "label": "GAS_SENSE"},
    {"pin": "PA1", "signal": "GPIO_Input", "label": "GAS_DIGITAL"}
  ],
  "config": {
    "ADC1": {
      "Resolution": "ADC_RESOLUTION_12B",
      "ScanConvMode": "DISABLE",
      "ContinuousConvMode": "ENABLE",
      "ExternalTrigConv": "ADC_SOFTWARE_START",
      "DataAlign": "ADC_DATAALIGN_RIGHT"
    }
  },
  "sensor": {
    "type": "MQ-2 / MQ-135",
    "gases": ["LPG", "CO", "Smoke", "Alcohol", "NH3", "Benzene"],
    "heater_voltage": "5V",
    "load_resistor": "20KΩ",
    "preheat_time": "24-48 hours",
    "interface": "Analog + Digital"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
