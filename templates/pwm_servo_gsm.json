{
  "name": "PWM 舵机 GSM 控制配置",
  "description": "PWM 舵机 GSM 远程控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["USART1", "TIM3", "GPIO"],
  "pins": [
    {"pin": "PA9", "signal": "USART1_TX", "mode": "Asynchronous", "label": "GSM_TX"},
    {"pin": "PA10", "signal": "USART1_RX", "mode": "Asynchronous", "label": "GSM_RX"},
    {"pin": "PB0", "signal": "GPIO_Output", "label": "GSM_PWR"},
    {"pin": "PB1", "signal": "GPIO_Output", "label": "GSM_RST"},
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "SERVO_1"},
    {"pin": "PA7", "signal": "TIM3_CH2", "mode": "PWM Generation2 CH2", "label": "SERVO_2"}
  ],
  "config": {
    "USART1": {
      "BaudRate": 9600,
      "WordLength": "UART_WORDLENGTH_8B",
      "StopBits": "UART_STOPBITS_1",
      "Parity": "UART_PARITY_NONE",
      "Mode": "MODE_TX_RX"
    },
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "20000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Channel-PWM Generation2 CH2": "TIM_CHANNEL_2",
      "Pulse-PWM Generation1 CH1": "1500",
      "Pulse-PWM Generation2 CH2": "1500"
    }
  },
  "servo": {
    "type": "GSM Servo Control",
    "gsm": "SIM800/SIM900",
    "channels": 2,
    "protocol": "SMS/Call/GPRS"
  },
  "nvic": {
    "USART1_IRQn": {"priority": 5, "enabled": true}
  },
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
