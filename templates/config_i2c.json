{
  "name": "I2C 配置模板",
  "description": "I2C 外设配置模板",
  "parameters": {
    "i2c": {
      "type": "string",
      "default": "I2C1",
      "options": ["I2C1", "I2C2", "I2C3"],
      "description": "I2C 外设名称"
    },
    "speed": {
      "type": "integer",
      "default": 400000,
      "options": [100000, 400000],
      "description": "I2C 速度"
    },
    "addressing": {
      "type": "integer",
      "default": 7,
      "options": [7, 10],
      "description": "地址模式"
    }
  },
  "usage": "python cubemx_config.py --modify project.ioc --config-i2c --i2c I2C1 --speed 400000 --addressing 7"
}
