{
  "name": "继电器和蜂鸣器配置",
  "description": "继电器和蜂鸣器控制配置",
  "mcu": "STM32F407VETx",
  "peripherals": ["TIM3", "GPIO"],
  "pins": [
    {"pin": "PA6", "signal": "TIM3_CH1", "mode": "PWM Generation1 CH1", "label": "BUZZER"},
    {"pin": "PB0", "signal": "GPIO_Output", "label": "RELAY_1"},
    {"pin": "PB1", "signal": "GPIO_Output", "label": "RELAY_2"},
    {"pin": "PB2", "signal": "GPIO_Output", "label": "RELAY_3"},
    {"pin": "PB10", "signal": "GPIO_Output", "label": "RELAY_4"}
  ],
  "config": {
    "TIM3": {
      "Prescaler": "84-1",
      "Period": "1000-1",
      "Channel-PWM Generation1 CH1": "TIM_CHANNEL_1",
      "Pulse-PWM Generation1 CH1": "500"
    }
  },
  "relay": {
    "type": "5V/12V Relay Module",
    "channels": 4,
    "max_contact_voltage": "250VAC/30VDC",
    "max_contact_current": "10A"
  },
  "buzzer": {
    "type": "Active/Passive",
    "frequency": "1-20kHz",
    "drive": "PWM / GPIO"
  },
  "nvic": {},
  "clock": {
    "hse": 8,
    "sysclk": 168
  }
}
